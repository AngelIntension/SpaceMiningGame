# EditorConfig for VoidHarvest
# https://editorconfig.org
# Roslyn analyzer configuration for immutability enforcement
# See: .specify/memory/constitution.md (Technical Standards, Testing & Quality)

root = true

# =============================================================================
# Global defaults
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# =============================================================================
# C# source files — formatting and Roslyn analyzers
# =============================================================================
[*.cs]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
tab_width = 4
insert_final_newline = true
trim_trailing_whitespace = true

# -----------------------------------------------------------------------------
# C# formatting rules
# -----------------------------------------------------------------------------

# Organize usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# this. and Me. preferences — prefer no qualifier
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# Language keywords vs BCL types preferences — prefer language keywords
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# var preferences — prefer explicit types for clarity (functional style)
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-level preferences
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_explicit_tuple_names = true:warning
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_style_inlined_variable_declaration = true:suggestion
csharp_prefer_simple_default_expression = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion

# Expression-bodied members — allow but don't enforce
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_operators = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_indexers = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion
csharp_style_expression_bodied_lambdas = when_on_single_line:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion

# Null-checking preferences — favor modern patterns
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:warning

# Modifier preferences
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:suggestion
dotnet_style_readonly_field = true:warning

# Braces
csharp_prefer_braces = true:suggestion

# New line preferences
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_block_contents = true
csharp_indent_braces = false

# Spacing
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false

# Using directives
csharp_using_directive_placement = outside_namespace:warning

# Namespace declarations — file-scoped for C# 10+, block for C# 9
csharp_style_namespace_declarations = block_scope:suggestion

# -----------------------------------------------------------------------------
# Roslyn analyzer rules — Immutability enforcement (Constitution requirement)
# See: Constitution § Testing & Quality Standards > Static Analysis
# -----------------------------------------------------------------------------

# CA1024: Use properties where appropriate
# Encourages property-based access patterns over method-based getters
dotnet_diagnostic.CA1024.severity = suggestion

# CA1051: Do not declare visible instance fields
# CRITICAL for immutability — domain types must not expose mutable public fields.
# Record types and readonly structs naturally satisfy this. Types that violate
# this rule are likely holding mutable state outside the reducer pattern.
dotnet_diagnostic.CA1051.severity = error

# CA1822: Mark members as static
# Pure functions that don't use instance state should be static, reinforcing
# the functional paradigm (stateless logic operating on data).
dotnet_diagnostic.CA1822.severity = suggestion

# CA2227: Collection properties should be read only
# CRITICAL for immutability — prevents replacing collection instances on domain
# types. Use ImmutableArray<T> / ImmutableDictionary<K,V> or init-only setters.
dotnet_diagnostic.CA2227.severity = error

# Additional immutability and quality rules

# CA1034: Nested types should not be visible
# Encourages flat, composable type hierarchies (Data-Oriented Design principle)
dotnet_diagnostic.CA1034.severity = suggestion

# CA1040: Avoid empty interfaces
dotnet_diagnostic.CA1040.severity = warning

# CA1062: Validate arguments of public methods
dotnet_diagnostic.CA1062.severity = suggestion

# CA1716: Identifiers should not match keywords
dotnet_diagnostic.CA1716.severity = suggestion

# CA1815: Override equals and operator equals on value types
# Important for record struct and readonly struct correctness
dotnet_diagnostic.CA1815.severity = warning

# CA1819: Properties should not return arrays
# Arrays are mutable — prefer ImmutableArray<T> or ReadOnlySpan<T>
dotnet_diagnostic.CA1819.severity = warning

# CA2211: Non-constant fields should not be visible
# Prevents mutable static fields — no mutable globals (Constitution § II)
dotnet_diagnostic.CA2211.severity = error

# IDE0044: Add readonly modifier
# Ensures fields that are never reassigned are marked readonly
dotnet_diagnostic.IDE0044.severity = warning

# IDE0051: Remove unused private members
dotnet_diagnostic.IDE0051.severity = warning

# IDE0052: Remove unread private members
dotnet_diagnostic.IDE0052.severity = warning

# =============================================================================
# Unity-specific relaxations
# MonoBehaviours and ScriptableObjects use [SerializeField] which requires
# non-readonly fields. These are view-layer / data-authoring types only —
# they MUST NOT hold game state (Constitution § IV, Data-Oriented Design).
# =============================================================================

# Views layer — MonoBehaviours with serialized fields
[Assets/Features/*/Views/**/*.cs]
dotnet_diagnostic.CA1051.severity = suggestion
dotnet_diagnostic.CA2227.severity = suggestion
dotnet_diagnostic.CA1819.severity = suggestion

# ScriptableObject Config files — designer-authored static data
[Assets/Features/*/Data/*Config.cs]
dotnet_diagnostic.CA1051.severity = suggestion
dotnet_diagnostic.CA2227.severity = suggestion
dotnet_diagnostic.CA1819.severity = suggestion

# ScriptableObject Definition files — designer-authored static data
[Assets/Features/*/Data/*Definition.cs]
dotnet_diagnostic.CA1051.severity = suggestion
dotnet_diagnostic.CA2227.severity = suggestion
dotnet_diagnostic.CA1819.severity = suggestion

# Core Views layer (if any shared MonoBehaviours exist)
[Assets/Core/*/Views/**/*.cs]
dotnet_diagnostic.CA1051.severity = suggestion
dotnet_diagnostic.CA2227.severity = suggestion

# Editor scripts — may need mutable state for Editor tooling
[Assets/Editor/**/*.cs]
dotnet_diagnostic.CA1051.severity = suggestion
dotnet_diagnostic.CA2227.severity = suggestion
dotnet_diagnostic.CA1822.severity = none

# Test files — relaxed rules for test readability
[Assets/Features/*/Tests/**/*.cs]
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1822.severity = none

# =============================================================================
# Unity YAML / JSON / XML — formatting only
# =============================================================================
[*.{unity,prefab,asset,mat,anim,controller,meta}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.xml]
indent_style = space
indent_size = 2

[*.{asmdef,asmref}]
indent_style = space
indent_size = 4

# =============================================================================
# Shader files
# =============================================================================
[*.{shader,cginc,hlsl,compute}]
indent_style = space
indent_size = 4
end_of_line = lf

# =============================================================================
# Markdown / documentation
# =============================================================================
[*.md]
trim_trailing_whitespace = false
